{
  "name": "gray-swatch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "check:prettier": "prettier --check .",
    "check:lint": "eslint",
    "check:ts": "vue-tsc --noEmit",
    "check:all": "pnpm check:prettier && pnpm check:lint && pnpm check:ts",
    "fix:prettier": "prettier --log-level warn --write .",
    "fix:lint": "pnpm check:lint --fix",
    "fix:all": "pnpm fix:prettier && pnpm fix:lint"
  },
  "dependencies": {
    "@erwanjugand/eslint-config": "2.0.0",
    "@fontsource/roboto": "5.2.10",
    "@mdi/font": "7.4.47",
    "@vueuse/core": "14.2.1",
    "color-convert": "3.1.3",
    "vue": "3.5.29",
    "vuetify": "4.0.1"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@vitejs/plugin-vue": "6.0.5",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "unplugin-fonts": "1.4.0",
    "vite": "8.0.0",
    "vite-plugin-vuetify": "2.1.3",
    "vue-tsc": "3.2.5"
  }
}
