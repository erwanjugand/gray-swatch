{
  "name": "gray-swatch",
  "packageManager": "pnpm@11.9.0",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "check:prettier": "prettier --check .",
    "check:lint": "eslint",
    "check:ts": "vue-tsc --build --noEmit",
    "check:all": "pnpm check:prettier && pnpm check:lint && pnpm check:ts",
    "fix:prettier": "prettier --log-level warn --write .",
    "fix:lint": "pnpm check:lint --fix",
    "fix:all": "pnpm fix:prettier && pnpm fix:lint"
  },
  "dependencies": {
    "@erwanjugand/eslint-config": "2.4.0",
    "@fontsource/roboto": "5.2.10",
    "@mdi/font": "7.4.47",
    "@vueuse/core": "14.3.0",
    "color-convert": "3.1.3",
    "vue": "3.5.39",
    "vuetify": "4.1.3"
  },
  "devDependencies": {
    "@erwanjugand/prettier-config": "1.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "jiti": "2.7.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "unplugin-fonts": "2.0.0",
    "vite": "8.1.3",
    "vite-plugin-vuetify": "2.1.3",
    "vue-tsc": "3.3.6"
  }
}
